<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Softflip OS</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/admin/css/admin-style.css" asp-append-version="true" />
    <style>
        :root {
            --sidebar-width: 280px;
            --brand-gradient: linear-gradient(135deg, #048EE7 0%, #00C6FF 100%);
            --sidebar-bg: rgba(10, 15, 28, 0.6);
            --glass-border: rgba(255, 255, 255, 0.08);
        }
        
        body.admin-body {
            font-family: 'Inter', sans-serif;
            background: #050810 radial-gradient(circle at 50% 0%, rgba(4, 142, 231, 0.1) 0%, transparent 50%);
            color: #fff;
        }

        h1, h2, h3, h4, h5, h6, .brand-font {
            font-family: 'Outfit', sans-serif;
        }

        /* Enhanced Sidebar */
        .sidebar {
            width: var(--sidebar-width);
            background: var(--sidebar-bg);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-right: 1px solid var(--glass-border);
            position: fixed;
            top: 0;
            left: 0;
            height: 100vh;
            display: flex;
            flex-direction: column;
            z-index: 1000;
            box-shadow: 4px 0 24px rgba(0,0,0,0.2);
        }

        .sidebar-header {
            padding: 30px 24px;
            display: flex;
            align-items: center;
            border-bottom: 1px solid var(--glass-border);
        }

        .logo-icon-wrapper {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            background: var(--brand-gradient);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.2rem;
            color: white;
            box-shadow: 0 4px 15px rgba(4, 142, 231, 0.4);
            margin-right: 15px;
        }

        .logo-text-admin {
            font-size: 1.4rem;
            font-weight: 800;
            letter-spacing: -0.5px;
            background: linear-gradient(to right, #fff, #a8c0ff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .nav-menu {
            padding: 24px 12px;
            flex: 1;
            overflow-y: auto;
        }
        
        .nav-menu::-webkit-scrollbar {
            width: 4px;
        }
        .nav-menu::-webkit-scrollbar-thumb {
            background: rgba(255,255,255,0.1);
            border-radius: 4px;
        }

        .nav-section-title {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: rgba(255,255,255,0.3);
            font-weight: 700;
            margin: 20px 0 10px 16px;
        }

        .nav-link {
            color: #8b9bb4;
            padding: 12px 16px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            margin-bottom: 4px;
            font-weight: 500;
        }

        .nav-link:hover {
            background: rgba(255, 255, 255, 0.05);
            color: #fff;
            transform: translateX(4px);
        }

        .nav-link.active {
            background: var(--brand-gradient);
            color: #fff;
            box-shadow: 0 4px 15px rgba(4, 142, 231, 0.25);
            font-weight: 600;
        }

        .nav-link i {
            margin-right: 14px;
            font-size: 1.2rem;
            transition: transform 0.3s;
        }

        .nav-link.active i {
            transform: scale(1.1);
        }

        .sidebar-footer {
            padding: 24px;
            border-top: 1px solid var(--glass-border);
            background: rgba(0,0,0,0.2);
        }

        .btn-logout {
            background: rgba(220, 53, 69, 0.1);
            color: #ff6b6b;
            border: 1px solid rgba(220, 53, 69, 0.2);
            transition: all 0.3s;
        }

        .btn-logout:hover {
            background: rgba(220, 53, 69, 0.2);
            color: #ff6b6b;
            box-shadow: 0 4px 15px rgba(220, 53, 69, 0.15);
        }

        /* Enhanced Main Content */
        .main-content {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .top-header {
            height: 80px;
            padding: 0 40px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            background: rgba(5, 8, 16, 0.8);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--glass-border);
            position: sticky;
            top: 0;
            z-index: 900;
        }

        .page-title {
            font-size: 1.4rem;
            margin: 0;
            font-weight: 600;
            color: #fff;
        }

        .user-profile {
            background: rgba(255,255,255,0.03);
            border: 1px solid var(--glass-border);
            padding: 6px 16px 6px 6px;
            border-radius: 50px;
            transition: background 0.3s;
        }
        
        .user-profile:hover {
            background: rgba(255,255,255,0.06);
            cursor: pointer;
        }

        .content-body {
            padding: 40px;
            flex: 1;
        }

        /* Responsive Mobile Styles */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.5);
            backdrop-filter: blur(4px);
            z-index: 990;
        }

        .mobile-toggle {
            display: none;
            background: transparent;
            border: none;
            color: white;
            font-size: 1.8rem;
            padding: 0;
            margin-right: 15px;
        }

        @@media (max-width: 991px) {
            .sidebar {
                transform: translateX(-100%);
                transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            }
            .sidebar.show {
                transform: translateX(0);
            }
            .main-content {
                margin-left: 0;
            }
            .top-header {
                padding: 0 20px;
                height: 70px;
            }
            .content-body {
                padding: 20px;
            }
            .mobile-toggle {
                display: block;
            }
            .sidebar-backdrop.show {
                display: block;
            }
            .page-title {
                font-size: 1.2rem;
            }
        }

        @@media (max-width: 576px) {
            .user-profile .text-end {
                display: none;
            }
        }
    </style>
</head>
<body class="admin-body">

    <div class="sidebar-backdrop" id="sidebarBackdrop" onclick="toggleSidebar()"></div>

    <aside class="sidebar" id="adminSidebar">
        <div class="sidebar-header">
            <div class="logo-icon-wrapper">
                <i class="bi bi-hexagon-fill"></i>
            </div>
            <div class="logo-text-admin">Softflip OS</div>
        </div>
        <div class="nav-menu">
            <div class="nav-section-title">Overview</div>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-action="Index" asp-controller="Admin">
                <i class="bi bi-grid-1x2-fill"></i> Dashboard
            </a>
            
            <div class="nav-section-title mt-4">Inbox & Leads</div>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Enquiries" ? "active" : "")" asp-action="Enquiries" asp-controller="Admin">
                <i class="bi bi-envelope-paper-fill"></i> Enquiries
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DemoRequests" ? "active" : "")" asp-action="DemoRequests" asp-controller="Admin">
                <i class="bi bi-laptop-fill"></i> Demo Requests
            </a>

            <div class="nav-section-title mt-4">Pipeline</div>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "ConfirmedClients" ? "active" : "")" asp-action="ConfirmedClients" asp-controller="Admin">
                <i class="bi bi-check-circle-fill @(ViewContext.RouteData.Values["Action"]?.ToString() == "ConfirmedClients" ? "text-white" : "text-success")"></i> Confirmed
            </a>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "RejectedClients" ? "active" : "")" asp-action="RejectedClients" asp-controller="Admin">
                <i class="bi bi-x-circle-fill @(ViewContext.RouteData.Values["Action"]?.ToString() == "RejectedClients" ? "text-white" : "text-danger")"></i> Rejected
            </a>

            <div class="nav-section-title mt-4">System</div>
            <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "active" : "")" asp-action="Settings" asp-controller="Admin">
                <i class="bi bi-gear-fill @(ViewContext.RouteData.Values["Action"]?.ToString() == "Settings" ? "text-white" : "text-warning")"></i> Settings
            </a>
        </div>
        <div class="sidebar-footer">
            <a asp-action="Logout" asp-controller="Admin" class="btn btn-logout w-100 rounded-pill fw-medium d-flex align-items-center justify-content-center">
                <i class="bi bi-box-arrow-right me-2"></i> Sign Out
            </a>
        </div>
    </aside>

    <div class="main-content">
        <header class="top-header">
            <div class="d-flex align-items-center">
                <button class="mobile-toggle" onclick="toggleSidebar()">
                    <i class="bi bi-list"></i>
                </button>
                <h2 class="page-title brand-font">@ViewData["Title"]</h2>
            </div>
            <div class="user-profile d-flex align-items-center">
                <img src="https://ui-avatars.com/api/?name=Admin&background=048EE7&color=fff&bold=true" class="rounded-circle me-3" width="36" height="36" alt="Admin">
                <div class="me-2 text-end">
                    <div class="fw-bold fs-6 text-white lh-1">Administrator</div>
                    <div class="text-success small fw-medium mt-1"><i class="bi bi-circle-fill me-1" style="font-size: 8px;"></i>Online</div>
                </div>
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleSidebar() {
            document.getElementById('adminSidebar').classList.toggle('show');
            document.getElementById('sidebarBackdrop').classList.toggle('show');
        }
    </script>
</body>
</html>
