<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin Portal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/admin/css/admin-style.css" asp-append-version="true" />
    
</head>
<body class="admin-body">

    <aside class="sidebar">
        <div class="sidebar-header">
            <div class="logo-icon"><i class="bi bi-layers-fill"></i></div>
            <div class="logo-text">Softflip Admin</div>
        </div>
        <div class="nav-menu">
            <div class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" ? "active" : "")" asp-action="Index" asp-controller="Admin">
                    <i class="bi bi-grid-1x2-fill"></i> Dashboard
                </a>
            </div>
            <div class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "Enquiries" ? "active" : "")" asp-action="Enquiries" asp-controller="Admin">
                    <i class="bi bi-chat-left-dots-fill"></i> Enquiries
                </a>
            </div>
            <div class="nav-item">
                <a class="nav-link @(ViewContext.RouteData.Values["Action"]?.ToString() == "DemoRequests" ? "active" : "")" asp-action="DemoRequests" asp-controller="Admin">
                    <i class="bi bi-calendar-event-fill"></i> Demo Requests
                </a>
            </div>
        </div>
        <div class="sidebar-footer">
            <a asp-action="Logout" asp-controller="Admin" class="btn btn-outline-danger w-100 d-flex align-items-center justify-content-center">
                <i class="bi bi-box-arrow-right me-2"></i> Logout
            </a>
        </div>
    </aside>

    <div class="main-content">
        <header class="top-header">
            <h2 class="page-title">@ViewData["Title"]</h2>
            <div class="user-profile d-flex align-items-center">
                <div class="me-3 text-end">
                    <div class="fw-bold fs-6">Administrator</div>
                    <div class="text-muted small">Online</div>
                </div>
                <img src="https://ui-avatars.com/api/?name=Admin&background=00f2fe&color=050810" class="rounded-circle" width="40" height="40" alt="Admin">
            </div>
        </header>

        <main class="content-body">
            @RenderBody()
        </main>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
