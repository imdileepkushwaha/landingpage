@{
    ViewData["Title"] = "Dashboard Overview";
    Layout = "_AdminLayout";
}

<div class="row g-4 mb-4">
    <div class="col-md-6 col-lg-4">
        <div class="glass-card d-flex align-items-center h-100 position-relative overflow-hidden">
            <!-- decorative blur -->
            <div class="admin-stat-blur-1"></div>
            
            <div class="me-4 rounded-3 d-flex align-items-center justify-content-center admin-stat-icon-1">
                <i class="bi bi-envelope-paper-fill"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium text-uppercase">Total Enquiries</p>
                <h3 class="mb-0 display-6 fw-bold">@ViewBag.TotalEnquiries</h3>
            </div>
        </div>
    </div>
    <div class="col-md-6 col-lg-4">
        <div class="glass-card d-flex align-items-center h-100 position-relative overflow-hidden">
             <!-- decorative blur -->
            <div class="admin-stat-blur-2"></div>

            <div class="me-4 rounded-3 d-flex align-items-center justify-content-center admin-stat-icon-2">
                <i class="bi bi-calendar-check-fill"></i>
            </div>
            <div>
                <p class="text-muted mb-1 small fw-medium text-uppercase">Demo Requests</p>
                <h3 class="mb-0 display-6 fw-bold">@ViewBag.TotalDemoRequests</h3>
            </div>
        </div>
    </div>
    <div class="col-md-12 col-lg-4">
        <div class="glass-card h-100 d-flex flex-column justify-content-center text-center admin-quick-actions">
            <h5 class="fw-bold mb-3">Quick Actions</h5>
            <div class="d-flex justify-content-center gap-3">
                <a asp-action="Enquiries" class="btn btn-outline-light btn-sm rounded-pill px-3">View Inbox</a>
                <a asp-action="DemoRequests" class="btn btn-gradient btn-sm rounded-pill px-3 text-dark">Schedule Demo</a>
            </div>
        </div>
    </div>
</div>

<div class="row">
    <div class="col-12">
        <div class="glass-card">
            <h5 class="mb-4">System Status</h5>
            <div class="d-flex align-items-center">
                <div class="spinner-grow spinner-grow-sm text-success me-2" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <span class="text-muted">Softflip V3 Engine is running smoothly. All services operational.</span>
            </div>
        </div>
    </div>
</div>
