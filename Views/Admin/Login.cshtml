@{
    ViewData["Title"] = "Admin Secure Login";
    Layout = null; // No layout for login page
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - SoftflipSolutions</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/admin/css/admin-style.css" asp-append-version="true" />
</head>
<body class="admin-login-body">
    <div class="login-card text-center">
        <div class="login-icon">
            <i class="bi bi-shield-lock-fill"></i>
        </div>
        <h2 class="mb-2">Admin Portal</h2>
        <p class="text-white-50 mb-4 small">Enter your credentials to securely access the dashboard.</p>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-glass p-3 mb-4 text-start d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>
                <small>@ViewBag.Error</small>
            </div>
        }
        
        <form asp-action="Login" method="post">
            <div class="input-group mb-3">
                <span class="input-group-text"><i class="bi bi-person-fill"></i></span>
                <input type="text" class="form-control" name="username" placeholder="Username" required autocomplete="off" />
            </div>
            <div class="input-group mb-4">
                <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                <input type="password" class="form-control" name="password" placeholder="Password" required />
            </div>
            
            <button type="submit" class="btn btn-gradient w-100 d-flex align-items-center justify-content-center">
                Sign In <i class="bi bi-box-arrow-in-right ms-2 fs-5"></i>
            </button>
        </form>
        
        <div class="mt-4 pt-3 border-top border-secondary login-border-top">
            <a href="/" class="text-white-50 text-decoration-none small hover-white transition-all">
                <i class="bi bi-arrow-left me-1"></i> Return to Homepage
            </a>
        </div>
    </div>
</body>
</html>
