@{
    ViewData["Title"] = "Admin Secure Login";
    Layout = null; // No layout for login page
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Admin Login - SoftflipSolutions</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Poppins:wght@600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-icons/1.10.5/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/admin/css/admin-style.css" asp-append-version="true" />
</head>

<body class="admin-login-body">
    <!-- <div class="softflip-brand d-none d-md-block">Softflip<span>Solutions</span></div> -->
    <div class="login-card text-center">
        <div class="login-icon">
            <i class="bi bi-shield-lock-fill text-white"></i>
        </div>
        <h2 class="mb-2">Admin Portal</h2>
        <p class="text-white-50 mb-4 small">Secure Access Dashboard</p>
        
        @if (ViewBag.Error != null)
        {
            <div class="alert alert-glass border-danger p-3 mb-4 text-start d-flex align-items-center">
                <i class="bi bi-shield-x text-danger fs-4 me-3"></i>
                <small class="text-white">@ViewBag.Error</small>
            </div>
        }
        
        <form asp-action="Login" method="post" class="text-start">
            <div class="custom-input-group">
                <input type="text" class="form-control" name="username" placeholder="Username" required autocomplete="off" />
                <i class="bi bi-person-fill input-icon"></i>
            </div>
            <div class="custom-input-group mb-4">
                <input type="password" class="form-control" name="password" placeholder="Password" required />
                <i class="bi bi-key-fill input-icon"></i>
            </div>
            
            <button type="submit" class="btn btn-login w-100 d-flex align-items-center justify-content-center">
                Authenticate Securely <i class="bi bi-fingerprint ms-2 fs-5"></i>
            </button>
        </form>
        
        <div class="mt-4 pt-4 border-top border-secondary login-border-top text-center">
            <a href="/" class="text-white-50 text-decoration-none small hover-white transition-all">
                <i class="bi bi-arrow-left me-1"></i> Return to Main Website
            </a>
        </div>
    </div>
</body>
</html>
