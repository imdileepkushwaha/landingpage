@model IEnumerable<SoftflipSolutions.Models.Enquiry>
@{
    ViewData["Title"] = "Customer Enquiries";
    Layout = "_AdminLayout";
}

<div class="glass-card p-0 overflow-hidden">
    <div class="p-4 border-bottom d-flex justify-content-between align-items-center admin-table-header" style="border-color: rgba(255,255,255,0.08) !important;">
        <h5 class="mb-0 text-white">Recent Submissions</h5>
        <span class="badge bg-primary bg-opacity-25 text-info border border-primary border-opacity-50 px-3 py-2 rounded-pill">Total: @Model.Count()</span>
    </div>
    <div class="table-responsive">
        <table class="table table-borderless mb-0 align-middle">
            <thead>
                <tr>
                    <th>Date Received</th>
                    <th>Customer Name</th>
                    <th>Contact Info</th>
                    <th>Requirement & Message</th>
                    <th class="text-end">Action</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="text-muted small">
                            <i class="bi bi-clock me-1"></i> @item.CreatedAt.ToString("MMM dd, yyyy HH:mm")
                        </td>
                        <td class="fw-bold">@item.Name</td>
                        <td>
                            <div class="d-flex flex-column">
                                <a href="mailto:@item.Email" class="text-info text-decoration-none small"><i class="bi bi-envelope me-1"></i> @item.Email</a>
                                <span class="text-muted small mt-1"><i class="bi bi-telephone me-1"></i> @item.Phone</span>
                            </div>
                        </td>
                        <td class="admin-msg-col">
                            <div class="mb-1">
                                <span class="badge bg-secondary">@item.Requirement</span>
                            </div>
                            <div class="text-truncate text-muted small" style="max-width: 250px;" title="@item.Message">
                                @item.Message
                            </div>
                        </td>
                        <td class="text-end">
                            <a asp-action="EnquiryDetails" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">View Details</a>
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr>
                        <td colspan="5" class="text-center py-5">
                            <div class="text-muted mb-2"><i class="bi bi-inbox fs-1"></i></div>
                            <h6>No enquiries found</h6>
                            <p class="small">When users submit the form, they will appear here.</p>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
